# Copy this file to your real environment and replace placeholders.
# Never commit real credentials.

# AWS
AWS_REGION=eu-west-1
S3_BUCKET=your-s3-bucket-name
S3_PREFIX=street-incidents

# S3 URL options:
# presigned  = temporary URL, max recommended value below is 604800 seconds / 7 days.
# public     = public S3 object URL or S3_PUBLIC_BASE_URL if set.
# cloudfront = CLOUDFRONT_BASE_URL/object-key, best for stable external URLs.
S3_URL_MODE=presigned
S3_PRESIGNED_EXPIRES_SECONDS=604800
S3_PUBLIC_BASE_URL=
CLOUDFRONT_BASE_URL=

# Bedrock / Nova
# For Europe cross-region inference profile use eu.amazon.nova-lite-v1:0 or eu.amazon.nova-pro-v1:0.
# For direct model IDs, use the model ID enabled in your selected Bedrock region.
BEDROCK_MODEL_ID=eu.amazon.nova-lite-v1:0
BEDROCK_MAX_TOKENS=800
BEDROCK_TEMPERATURE=0.1

# YOLOE
DETECTOR_MODEL_PATH=yoloe-26x-seg.pt
DETECTOR_CONFIDENCE=0.25

# AWS IoT Core MQTT over WebSockets
IOT_ENDPOINT=your-iot-endpoint-ats.iot.eu-west-1.amazonaws.com
IOT_CLIENT_ID=street-incident-ai-local
IOT_TOPIC=street/incidents/test

# Salesforce OAuth + case endpoint
SALESFORCE_HOST=your-host
SALESFORCE_CLIENT_ID=replace-with-client-id
SALESFORCE_CLIENT_SECRET=replace-with-client-secret
# Optional overrides. If empty, generated from SALESFORCE_HOST.
SALESFORCE_TOKEN_URL=
SALESFORCE_CASE_URL=

# Local folders/logging
OUTPUT_DIR=data/output
TMP_DIR=tmp
LOG_LEVEL=INFO

# Use these for local integration tests without paid/external calls.
DRY_RUN_BEDROCK=false
DRY_RUN_IOT=false
DRY_RUN_SALESFORCE=false
